# hybrid-recsys configuration
# Copy to .env and adjust as needed. All vars are prefixed with RECSYS_.

# Provider selection
RECSYS_EMBEDDING_PROVIDER=sentence-transformers   # sentence-transformers | openai
RECSYS_LLM_PROVIDER=mock                          # mock | openai
RECSYS_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# OpenAI (required when using openai providers)
RECSYS_OPENAI_API_KEY=
RECSYS_OPENAI_BASE_URL=

# Duration scoring
RECSYS_DEFAULT_DURATION=600
RECSYS_DURATION_PENALTY=-1.0

# RRF parameters — program level
RECSYS_RRF_PROGRAM_WEIGHTS=[3.0,2.0]
RECSYS_RRF_PROGRAM_K=5

# RRF parameters — media level
RECSYS_RRF_MEDIA_WEIGHTS=[3.0,2.0,3.0]
RECSYS_RRF_MEDIA_K=8

# ANN parameters (Voyager HNSW)
RECSYS_ANN_METRIC=cosine
RECSYS_ANN_M=16
RECSYS_ANN_EF_CONSTRUCTION=200
RECSYS_ANN_QUERY_K=20

# Paths
RECSYS_DATA_DIR=data
